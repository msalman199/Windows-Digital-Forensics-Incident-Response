#!/usr/bin/env python3

def verify_timeline_consistency():
    """Verify timeline consistency and identify gaps"""
    print("=== Timeline Verification ===")
    
    # Read the forensic report
    try:
        with open("usb_forensic_report.txt", "r") as f:
            content = f.read()
        
        # Extract timeline section
        timeline_start = content.find("CHRONOLOGICAL TIMELINE:")
        if timeline_start != -1:
            timeline_section = content[timeline_start:]
            lines = timeline_section.split('\n')[2:]  # Skip header lines
            
            timeline_entries = []
            for line in lines:
                if line.strip() and not line.startswith('-'):
                    timeline_entries.append(line.strip())
            
            print(f"Timeline entries found: {len(timeline_entries)}")
            
            # Check for potential issues
            issues = []
            
            # Check for duplicate timestamps
            timestamps = []
            for entry in timeline_entries:
                if ' - ' in entry:
                    timestamp = entry.split(' - ')[0]
                    if timestamp in timestamps:
                        issues.append(f"Duplicate timestamp: {timestamp}")
                    timestamps.append(timestamp)
            
            # Report findings
            if issues:
                print("\nPotential Issues Found:")
                for issue in issues:
                    print(f"  - {issue}")
            else:
                print("\nTimeline appears consistent - no issues detected")
                
            print(f"\nTimeline spans {len(set(timestamps))} unique timestamps")
            
    except FileNotFoundError:
        print("Forensic report not found. Run correlation analysis first.")

if __name__ == "__main__":
    verify_timeline_consistency()
EOF

