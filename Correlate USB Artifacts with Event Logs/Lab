#!/usr/bin/env python3
import csv
from datetime import datetime
import re

def load_usb_artifacts():
    """Load USB artifacts from registry analysis"""
    artifacts = []
    try:
        with open("usb_artifacts.txt", "r") as f:
            for line in f:
                parts = line.strip().split(',')
                if len(parts) >= 4:
                    artifacts.append({
                        'vendor': parts[0],
                        'product': parts[1],
                        'serial': parts[2],
                        'first_install': parts[3]
                    })
    except FileNotFoundError:
        print("USB artifacts file not found. Run registry parser first.")
    return artifacts

def load_usb_events():
    """Load USB events from event log analysis"""
    events = []
    try:
        with open("usb_events.txt", "r") as f:
            for line in f:
                parts = line.strip().split(',')
                if len(parts) >= 4:
                    events.append({
                        'event_id': parts[0],
                        'timestamp': parts[1],
                        'action': parts[2],
                        'device_id': parts[3]
                    })
    except FileNotFoundError:
        print("USB events file not found. Run event log parser first.")
    return events

def correlate_usb_data(artifacts, events):
    """Correlate USB artifacts with event logs"""
    correlations = []
    
    for artifact in artifacts:
        # Find matching events for this device
        matching_events = []
        
        for event in events:
            # Try to match by device characteristics
            if (artifact['serial'] in event['device_id'] or 
                any(keyword in event['device_id'].lower() for keyword in 
                    [artifact['vendor'].lower(), artifact['product'].lower()])):
                matching_events.append(event)
        
        if matching_events:
            correlations.append({
                'device': f"{artifact['vendor']} {artifact['product']}",
                'serial': artifact['serial'],
                'first_install': artifact['first_install'],
                'events': matching_events
            })
    
    return correlations

def create_timeline(correlations):
    """Create chronological timeline of USB activity"""
    timeline_events = []
    
    for correlation in correlations:
        device_name = correlation['device']
        
        # Add first install event
        timeline_events.append({
            'timestamp': correlation['first_install'],
            'device': device_name,
            'action': 'FIRST_INSTALL',
            'source': 'Registry'
        })
        
        # Add event log entries
        for event in correlation['events']:
            timeline_events.append({
                'timestamp': event['timestamp'],
                'device': device_name,
                'action': event['action'],
                'source': f"Event Log (ID: {event['event_id']})"
            })
    
    # Sort by timestamp
    try:
        timeline_events.sort(key=lambda x: datetime.strptime(x['timestamp'], '%Y-%m-%d %H:%M:%S'))
    except:
        # If timestamp parsing fails, sort alphabetically
        timeline_events.sort(key=lambda x: x['timestamp'])
    
    return timeline_events

def display_correlations(correlations):
    """Display correlation results"""
    print("\n=== USB Artifact and Event Log Correlation ===")
    
    for i, correlation in enumerate(correlations, 1):
        print(f"\nDevice {i}: {correlation['device']}")
        print(f"Serial: {correlation['serial']}")
        print(f"First Install: {correlation['first_install']}")
        print(f"Related Events: {len(correlation['events'])}")
        
        for event in correlation['events']:
            print(f"  - {event['timestamp']}: {event['action']} (Event ID: {event['event_id']})")

def display_timeline(timeline):
    """Display chronological timeline"""
    print("\n=== USB Activity Timeline ===")
    print(f"{'Timestamp':<20} {'Device':<25} {'Action':<15} {'Source':<20}")
    print("-" * 85)
    
    for event in timeline:
        print(f"{event['timestamp']:<20} {event['device']:<25} {event['action']:<15} {event['source']:<20}")

def generate_report(correlations, timeline):
    """Generate forensic report"""
    with open("usb_forensic_report.txt", "w") as f:
        f.write("USB FORENSIC ANALYSIS REPORT\n")
        f.write("=" * 50 + "\n\n")
        
        f.write(f"Analysis Date: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
        f.write(f"Total Devices Found: {len(correlations)}\n")
        f.write(f"Total Timeline Events: {len(timeline)}\n\n")
        
        f.write("DEVICE CORRELATIONS:\n")
        f.write("-" * 30 + "\n")
        for i, correlation in enumerate(correlations, 1):
            f.write(f"Device {i}: {correlation['device']}\n")
            f.write(f"  Serial: {correlation['serial']}\n")
            f.write(f"  First Install: {correlation['first_install']}\n")
            f.write(f"  Events: {len(correlation['events'])}\n\n")
        
        f.write("CHRONOLOGICAL TIMELINE:\n")
        f.write("-" * 30 + "\n")
        for event in timeline:
            f.write(f"{event['timestamp']} - {event['device']} - {event['action']} ({event['source']})\n")

if __name__ == "__main__":
    print("Loading USB artifacts and events...")
    artifacts = load_usb_artifacts()
    events = load_usb_events()
    
    print(f"Loaded {len(artifacts)} artifacts and {len(events)} events")
    
    # Perform correlation
    correlations = correlate_usb_data(artifacts, events)
    timeline = create_timeline(correlations)
    
    # Display results
    display_correlations(correlations)
    display_timeline(timeline)
    
    # Generate report
    generate_report(correlations, timeline)
    print(f"\nForensic report saved to: usb_forensic_report.txt")
EOF

