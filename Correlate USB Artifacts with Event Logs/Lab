#!/usr/bin/env python3
import re
from datetime import datetime

def parse_event_logs(file_path):
    """Parse Windows event logs for USB-related events"""
    usb_events = []
    
    with open(file_path, 'r') as f:
        lines = f.readlines()
    
    for line in lines:
        if line.startswith('#'):
            continue
            
        # Parse event log entry
        event_pattern = r'EventID: (\d+), Time: ([^,]+), Source: ([^,]+), Description: (.+)'
        match = re.match(event_pattern, line.strip())
        
        if match:
            event_id = match.group(1)
            timestamp = match.group(2)
            source = match.group(3)
            description = match.group(4)
            
            # Filter USB-related events
            usb_keywords = ['USB', 'external device', 'PnP', 'Mass Storage']
            if any(keyword.lower() in description.lower() for keyword in usb_keywords):
                
                # Extract device identifier if present
                device_id = "Unknown"
                device_match = re.search(r'USB\\([^\\]+\\[^\\]+)', description)
                if device_match:
                    device_id = device_match.group(1)
                
                usb_events.append({
                    'event_id': event_id,
                    'timestamp': timestamp,
                    'source': source,
                    'description': description,
                    'device_id': device_id,
                    'action': determine_action(event_id, description)
                })
    
    return usb_events

def determine_action(event_id, description):
    """Determine USB action based on event ID and description"""
    if 'configured' in description.lower() or 'started' in description.lower():
        return 'CONNECTED'
    elif 'removed' in description.lower():
        return 'DISCONNECTED'
    elif 'recognized' in description.lower():
        return 'RECOGNIZED'
    else:
        return 'OTHER'

def display_usb_events(events):
    """Display USB events in formatted table"""
    print("\n=== USB Event Log Analysis ===")
    print(f"{'Event ID':<10} {'Timestamp':<20} {'Action':<12} {'Device ID':<30}")
    print("-" * 80)
    
    for event in events:
        print(f"{event['event_id']:<10} {event['timestamp']:<20} {event['action']:<12} {event['device_id']:<30}")

if __name__ == "__main__":
    events = parse_event_logs("sample_data/logs/System_events.txt")
    display_usb_events(events)
    
    # Save results for correlation
    with open("usb_events.txt", "w") as f:
        for event in events:
            f.write(f"{event['event_id']},{event['timestamp']},{event['action']},{event['device_id']}\n")
    
    print(f"\nFound {len(events)} USB-related events")
    print("Results saved to usb_events.txt")
EOF

