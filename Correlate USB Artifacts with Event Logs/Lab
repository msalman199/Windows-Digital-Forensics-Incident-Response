Task 2: Extract USB Artifacts from Registry Data
Subtask 2.1: Create USB Registry Parser
# Create USB registry parser script
cat > usb_registry_parser.py << 'EOF'
#!/usr/bin/env python3
import re
import datetime

def parse_usb_registry(file_path):
    """Parse USB artifacts from registry file"""
    usb_devices = []
    
    with open(file_path, 'r') as f:
        content = f.read()
    
    # Extract USBSTOR entries
    usbstor_pattern = r'USBSTOR\\([^\\]+)\\([^\\]+)'
    matches = re.findall(usbstor_pattern, content)
    
    for match in matches:
        device_info = match[0]
        serial = match[1].split('&')[0]
        
        # Extract device details
        vendor_match = re.search(r'Ven_([^&]+)', device_info)
        product_match = re.search(r'Prod_([^&]+)', device_info)
        
        vendor = vendor_match.group(1) if vendor_match else "Unknown"
        product = product_match.group(1) if product_match else "Unknown"
        
        # Extract timestamp
        timestamp_pattern = rf'{re.escape(serial)}.*?FirstInstallDate: ([^\n]+)'
        timestamp_match = re.search(timestamp_pattern, content)
        timestamp = timestamp_match.group(1) if timestamp_match else "Unknown"
        
        usb_devices.append({
            'vendor': vendor,
            'product': product,
            'serial': serial,
            'first_install': timestamp,
            'device_string': device_info
        })
    
    return usb_devices

def display_usb_artifacts(devices):
    """Display USB artifacts in formatted table"""
    print("\n=== USB Device Artifacts ===")
    print(f"{'Vendor':<15} {'Product':<20} {'Serial':<25} {'First Install':<20}")
    print("-" * 80)
    
    for device in devices:
        print(f"{device['vendor']:<15} {device['product']:<20} {device['serial']:<25} {device['first_install']:<20}")

if __name__ == "__main__":
    devices = parse_usb_registry("sample_data/registry/SYSTEM_sample.txt")
    display_usb_artifacts(devices)
    
    # Save results for correlation
    with open("usb_artifacts.txt", "w") as f:
        for device in devices:
            f.write(f"{device['vendor']},{device['product']},{device['serial']},{device['first_install']}\n")
    
    print(f"\nFound {len(devices)} USB devices")
    print("Results saved to usb_artifacts.txt")
EOF

