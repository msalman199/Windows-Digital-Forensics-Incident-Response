#!/usr/bin/env python3
import csv
import matplotlib.pyplot as plt
from datetime import datetime
import pandas as pd

def analyze_timeline(csv_file):
    """Analyze USB access timeline"""
    events = []
    
    with open(csv_file, 'r') as f:
        reader = csv.DictReader(f)
        for row in reader:
            events.append({
                'datetime': f"{row['Date']} {row['Time']}",
                'event': row['Event'],
                'device': row['Device'],
                'details': row['Details']
            })
    
    return events

def create_timeline_report(events):
    """Create detailed timeline report"""
    print("\n=== USB Access Timeline Analysis ===")
    print(f"{'Timestamp':<20} {'Event':<15} {'Device':<20} {'Details'}")
    print("-" * 85)
    
    for event in events:
        print(f"{event['datetime']:<20} {event['event']:<15} {event['device']:<20} {event['details']}")

def generate_statistics(events):
    """Generate access statistics"""
    device_counts = {}
    event_counts = {}
    
    for event in events:
        device = event['device']
        event_type = event['event']
        
        device_counts[device] = device_counts.get(device, 0) + 1
        event_counts[event_type] = event_counts.get(event_type, 0) + 1
    
    print("\n=== Access Statistics ===")
    print("Device Access Frequency:")
    for device, count in device_counts.items():
        print(f"  {device}: {count} events")
    
    print("\nEvent Type Distribution:")
    for event_type, count in event_counts.items():
        print(f"  {event_type}: {count} occurrences")

if __name__ == "__main__":
    events = analyze_timeline('evidence/timeline_data.csv')
    create_timeline_report(events)
    generate_statistics(events)
EOF

