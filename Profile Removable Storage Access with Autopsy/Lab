#!/usr/bin/env python3
import csv
import matplotlib.pyplot as plt
import matplotlib.dates as mdates
from datetime import datetime
import pandas as pd

def create_visual_timeline():
    """Create visual timeline of USB events"""
    events = []
    
    with open('evidence/timeline_data.csv', 'r') as f:
        reader = csv.DictReader(f)
        for row in reader:
            dt = datetime.strptime(f"{row['Date']} {row['Time']}", "%Y-%m-%d %H:%M:%S")
            events.append({
                'datetime': dt,
                'event': row['Event'],
                'device': row['Device']
            })
    
    # Create timeline plot
    fig, ax = plt.subplots(figsize=(12, 6))
    
    # Color mapping for different event types
    colors = {
        'USB_INSERT': 'green',
        'USB_REMOVE': 'red',
        'VOLUME_MOUNT': 'blue',
        'FILE_ACCESS': 'orange',
        'FILE_COPY': 'purple',
        'FILE_DELETE': 'brown'
    }
    
    for event in events:
        color = colors.get(event['event'], 'gray')
        ax.scatter(event['datetime'], event['device'], 
                  c=color, s=100, alpha=0.7, label=event['event'])
    
    # Format plot
    ax.set_xlabel('Time')
    ax.set_ylabel('Device')
    ax.set_title('USB Device Access Timeline')
    ax.xaxis.set_major_formatter(mdates.DateFormatter('%H:%M:%S'))
    ax.xaxis.set_major_locator(mdates.MinuteLocator(interval=30))
    plt.xticks(rotation=45)
    
    # Remove duplicate labels
    handles, labels = ax.get_legend_handles_labels()
    by_label = dict(zip(labels, handles))
    ax.legend(by_label.values(), by_label.keys(), bbox_to_anchor=(1.05, 1), loc='upper left')
    
    plt.tight_layout()
    plt.savefig('usb_timeline.png', dpi=300, bbox_inches='tight')
    print("Timeline visualization saved as 'usb_timeline.png'")

if __name__ == "__main__":
    create_visual_timeline()
EOF

