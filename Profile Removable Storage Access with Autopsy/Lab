#!/usr/bin/env python3
import re
import csv
from datetime import datetime

def parse_usb_registry(file_path):
    """Extract USB device information from registry file"""
    usb_devices = []
    
    try:
        with open(file_path, 'r') as f:
            content = f.read()
            
        # Extract USBSTOR entries
        usbstor_pattern = r'USBSTOR\\([^\\]+)\\([^\\]+)'
        matches = re.findall(usbstor_pattern, content)
        
        for match in matches:
            device_info = {
                'device_type': match[0],
                'serial_number': match[1],
                'timestamp': datetime.now().strftime('%Y-%m-%d %H:%M:%S')
            }
            usb_devices.append(device_info)
            
        # Extract USB VID/PID entries
        usb_pattern = r'USB\\VID_([0-9A-F]{4})&PID_([0-9A-F]{4})'
        vid_pid_matches = re.findall(usb_pattern, content)
        
        for i, match in enumerate(vid_pid_matches):
            if i < len(usb_devices):
                usb_devices[i]['vendor_id'] = match[0]
                usb_devices[i]['product_id'] = match[1]
    
    except Exception as e:
        print(f"Error parsing registry: {e}")
    
    return usb_devices

def generate_report(devices):
    """Generate USB device report"""
    print("\n=== USB Device Analysis Report ===")
    print(f"{'Device Type':<25} {'Serial Number':<20} {'VID:PID':<10} {'Timestamp'}")
    print("-" * 80)
    
    for device in devices:
        vid_pid = f"{device.get('vendor_id', 'N/A')}:{device.get('product_id', 'N/A')}"
        print(f"{device['device_type']:<25} {device['serial_number']:<20} {vid_pid:<10} {device['timestamp']}")

if __name__ == "__main__":
    devices = parse_usb_registry('evidence/usb_artifacts.reg')
    generate_report(devices)
EOF

