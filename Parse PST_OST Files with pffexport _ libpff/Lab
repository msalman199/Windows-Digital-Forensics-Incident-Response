Last modification time
Number of items
Encryption status
Step 3.2: Export PST Contents
mkdir -p ~/email_forensics/extracted
pffexport -t ~/email_forensics/extracted sample.pst
Step 3.3: Examine Extracted Structure
cd ~/email_forensics/extracted
find . -type f | head -20
ls -la
Step 3.4: Export with Detailed Options
cd ~/email_forensics/samples
pffexport -f all -t ~/email_forensics/detailed_export sample.pst
The -f all flag extracts:

Email messages
Attachments
Calendar items
Contacts
Tasks
Task 4: Analyze Email Artifacts
Step 4.1: Examine Email Messages
cd ~/email_forensics/extracted
find . -name "*.eml" | head -5 | while read file; do
    echo "=== Analyzing: $file ==="
    head -20 "$file"
    echo ""
done
Step 4.2: Search for Specific Content
# Search for emails containing specific keywords
grep -r -i "password\|confidential\|urgent" . --include="*.eml"
Step 4.3: Extract Email Headers
# Create a script to extract headers
cat > extract_headers.sh << 'EOF'
#!/bin/bash
for file in $(find . -name "*.eml"); do
    echo "=== Headers from: $file ==="
    sed -n '1,/^$/p' "$file" | grep -E "^(From|To|Subject|Date|Message-ID):"
    echo ""
done
EOF

chmod +x extract_headers.sh
./extract_headers.sh | head -30
Step 4.4: Analyze Attachments
# Find and list all attachments
find ~/email_forensics/extracted -type f ! -name "*.eml" -exec ls -lh {} \;

# Count attachment types
find ~/email_forensics/extracted -type f ! -name "*.eml" | sed 's/.*\.//' | sort | uniq -c
Task 5: Advanced Analysis with libpff
Step 5.1: Create Analysis Script
cat > analyze_pst.py << 'EOF'
#!/usr/bin/env python3
import os
import sys

def analyze_extracted_data(base_path):
    """Analyze extracted PST data"""
    
    email_count = 0
    attachment_count = 0
    total_size = 0
    
    for root, dirs, files in os.walk(base_path):
        for file in files:
            file_path = os.path.join(root, file)
            file_size = os.path.getsize(file_path)
            total_size += file_size
            
            if file.endswith('.eml'):
                email_count += 1
            elif not file.endswith('.eml'):
                attachment_count += 1
    
    print(f"Email Analysis Summary:")
    print(f"- Total emails: {email_count}")
    print(f"- Total attachments: {attachment_count}")
    print(f"- Total size: {total_size / 1024:.2f} KB")
    
    return email_count, attachment_count, total_size

if __name__ == "__main__":
    base_path = "/home/student/email_forensics/extracted"
    if os.path.exists(base_path):
        analyze_extracted_data(base_path)
    else:
        print("Extracted data directory not found")
EOF

chmod +x analyze_pst.py
python3 analyze_pst.py
Step 5.2: Timeline Analysis
# Create timeline of email activity
cat > email_timeline.sh << 'EOF'
#!/bin/bash
echo "Email Timeline Analysis"
echo "======================"

find ~/email_forensics/extracted -name "*.eml" -exec grep -l "Date:" {} \; | while read file; do
    date_line=$(grep "^Date:" "$file" | head -1)
    echo "$date_line - $(basename "$file")"
done | sort
EOF

chmod +x email_timeline.sh
./email_timeline.sh
Step 5.3: Generate Forensic Report
cat > forensic_report.sh << 'EOF'
#!/bin/bash
REPORT_FILE="~/email_forensics/forensic_report.txt"

echo "PST/OST Forensic Analysis Report" > $REPORT_FILE
echo "Generated: $(date)" >> $REPORT_FILE
echo "=================================" >> $REPORT_FILE
echo "" >> $REPORT_FILE

echo "1. File Information:" >> $REPORT_FILE
pffinfo ~/email_forensics/samples/sample.pst >> $REPORT_FILE 2>/dev/null
echo "" >> $REPORT_FILE

echo "2. Extraction Summary:" >> $REPORT_FILE
python3 analyze_pst.py >> $REPORT_FILE
echo "" >> $REPORT_FILE

echo "3. Email Headers Sample:" >> $REPORT_FILE
find ~/email_forensics/extracted -name "*.eml" | head -3 | while read file; do
    echo "--- $file ---" >> $REPORT_FILE
    sed -n '1,/^$/p' "$file" | head -10 >> $REPORT_FILE
    echo "" >> $REPORT_FILE
done

echo "Report generated: $REPORT_FILE"
cat $REPORT_FILE
EOF

chmod +x forensic_report.sh
./forensic_report.sh
