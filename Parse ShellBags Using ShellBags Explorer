# Install registry analysis tools
sudo apt install -y python3-registry

# Create Python script for ShellBag analysis
cat > analyze_shellbags.py << 'EOF'
#!/usr/bin/env python3
import sys
from Registry import Registry

def analyze_shellbags(registry_path):
    try:
        reg = Registry.Registry(open(registry_path, 'rb'))
        
        # Navigate to ShellBags key
        shellbags_key = reg.open("Software\\Microsoft\\Windows\\Shell\\BagMRU")
        
        print(f"Analyzing ShellBags from: {registry_path}")
        print("=" * 50)
        
        for subkey in shellbags_key.subkeys():
            print(f"Bag ID: {subkey.name()}")
            for value in subkey.values():
                print(f"  Value: {value.name()} = {value.value()}")
        
    except Exception as e:
        print(f"Error analyzing registry: {e}")
        print("Note: Sample files may not contain actual ShellBag data")

if __name__ == "__main__":
    analyze_shellbags("/home/user/forensics-lab/sample-data/NTUSER.DAT")
EOF

chmod +x analyze_shellbags.py
python3 analyze_shellbags.py
