#!/usr/bin/env python3
from Registry import Registry
import sys
from collections import defaultdict

def generate_report(system_hive):
    reg = Registry.Registry(system_hive)
    
    print("USB DEVICE FORENSIC REPORT")
    print("=" * 50)
    print()
    
    # Device summary
    device_count = defaultdict(int)
    unique_serials = set()
    
    try:
        usbstor_key = reg.open("ControlSet001\\Enum\\USBSTOR")
        
        for device in usbstor_key.subkeys():
            device_type = device.name().split('&')[0]
            device_count[device_type] += 1
            
            for instance in device.subkeys():
                if instance.name() != "Properties":
                    unique_serials.add(instance.name())
    except:
        pass
    
    print(f"Total Device Types: {len(device_count)}")
    print(f"Unique Serial Numbers: {len(unique_serials)}")
    print()
    
    print("Device Type Summary:")
    for device_type, count in device_count.items():
        print(f"  {device_type}: {count} instances")
    
    print("\nUnique Serial Numbers:")
    for serial in sorted(unique_serials):
        print(f"  {serial}")

if __name__ == "__main__":
    generate_report(sys.argv[1])
EOF

