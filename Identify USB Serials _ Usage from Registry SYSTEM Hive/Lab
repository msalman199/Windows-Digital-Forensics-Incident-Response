cat > extract_serials.py << 'EOF'
#!/usr/bin/env python3
from Registry import Registry
import sys

def extract_serials(system_hive):
    reg = Registry.Registry(system_hive)
    serials = []
    
    try:
        usbstor_key = reg.open("ControlSet001\\Enum\\USBSTOR")
        
        for device in usbstor_key.subkeys():
            for instance in device.subkeys():
                serial = instance.name()
                if serial != "Properties" and len(serial) > 5:
                    serials.append({
                        'device': device.name(),
                        'serial': serial,
                        'timestamp': instance.timestamp()
                    })
    except:
        pass
    
    print("USB Device Serials Found:")
    print("=" * 60)
    for item in serials:
        print(f"Device: {item['device']}")
        print(f"Serial: {item['serial']}")
        print(f"Last Modified: {item['timestamp']}")
        print("-" * 40)

if __name__ == "__main__":
    extract_serials(sys.argv[1])
EOF

