Subtask 1.2: Parse USB Storage Devices
Create a Python script to extract detailed USB information:

#!/usr/bin/env python3
# usb_parser.py

from Registry import Registry
import sys
from datetime import datetime

def parse_usb_devices(system_hive):
    reg = Registry.Registry(system_hive)
    
    print("=== USB Device Analysis ===\n")
    
    try:
        # Parse USBSTOR key for storage devices
        usbstor_key = reg.open("ControlSet001\\Enum\\USBSTOR")
        
        for device_key in usbstor_key.subkeys():
            print(f"Device: {device_key.name()}")
            
            for instance_key in device_key.subkeys():
                print(f"  Serial/Instance: {instance_key.name()}")
                
                try:
                    # Get device properties
                    friendly_name = instance_key.value("FriendlyName").value()
                    print(f"  Friendly Name: {friendly_name}")
                except:
                    pass
                
                try:
                    first_install = instance_key.value("FirstInstallTime").value()
                    # Convert Windows FILETIME to readable format
                    timestamp = datetime.fromtimestamp((first_install - 116444736000000000) / 10000000)
                    print(f"  First Install: {timestamp}")
                except:
                    pass
                
                print(f"  Last Write Time: {instance_key.timestamp()}")
                print("-" * 50)
                
    except Registry.RegistryKeyNotFoundException:
        print("USBSTOR key not found")
    
    # Parse USB key for additional device info
    try:
        usb_key = reg.open("ControlSet001\\Enum\\USB")
        print("\n=== USB Device Details ===\n")
        
        for vid_pid_key in usb_key.subkeys():
            if "VID_" in vid_pid_key.name():
                print(f"VID/PID: {vid_pid_key.name()}")
                
                for serial_key in vid_pid_key.subkeys():
                    print(f"  Serial: {serial_key.name()}")
                    print(f"  Last Write: {serial_key.timestamp()}")
                    print("-" * 30)
                    
    except Registry.RegistryKeyNotFoundException:
        print("USB key not found")

if __name__ == "__main__":
    if len(sys.argv) != 2:
        print("Usage: python3 usb_parser.py <SYSTEM_hive>")
        sys.exit(1)
    
    parse_usb_devices(sys.argv[1])
