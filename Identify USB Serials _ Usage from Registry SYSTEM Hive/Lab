#!/usr/bin/env python3
from Registry import Registry
import sys
from datetime import datetime

def analyze_timeline(system_hive):
    reg = Registry.Registry(system_hive)
    timeline = []
    
    # Collect timestamps from multiple sources
    sources = [
        "ControlSet001\\Enum\\USBSTOR",
        "ControlSet001\\Enum\\USB"
    ]
    
    for source in sources:
        try:
            key = reg.open(source)
            collect_timestamps(key, timeline, source)
        except:
            continue
    
    # Sort by timestamp
    timeline.sort(key=lambda x: x['timestamp'])
    
    print("USB Device Connection Timeline:")
    print("=" * 70)
    for event in timeline:
        print(f"{event['timestamp']} | {event['source']} | {event['device']}")

def collect_timestamps(key, timeline, source):
    for subkey in key.subkeys():
        timeline.append({
            'timestamp': subkey.timestamp(),
            'source': source.split('\\')[-1],
            'device': subkey.name()
        })
        
        # Recursively collect from subkeys
        for sub_subkey in subkey.subkeys():
            timeline.append({
                'timestamp': sub_subkey.timestamp(),
                'source': f"{source.split('\\')[-1]}/{subkey.name()}",
                'device': sub_subkey.name()
            })

if __name__ == "__main__":
    analyze_timeline(sys.argv[1])
EOF

