echo >> $REPORT_FILE
echo "RECOMMENDATIONS:" >> $REPORT_FILE
echo "- Monitor accounts with multiple failed logons" >> $REPORT_FILE
echo "- Investigate off-hours administrative access" >> $REPORT_FILE
echo "- Review remote logon patterns" >> $REPORT_FILE

echo "Report generated: $REPORT_FILE"
cat $REPORT_FILE

EOF

chmod +x security_report.sh
./security_report.sh
Task 4: Advanced Event Correlation
Subtask 4.1: Timeline Analysis
Create a timeline of logon events:

cat > timeline_analysis.sh << 'EOF'
#!/bin/bash

echo "=== Logon Timeline Analysis ==="
echo

# Sort events by time and create timeline
echo "Chronological Event Timeline:"
tail -n +2 logon_events.csv | sort -t',' -k1 | while IFS=',' read -r time event level keywords channel computer userid username logontype status; do
    case $event in
        4624) action="LOGON SUCCESS" ;;
        4625) action="LOGON FAILED" ;;
        4634) action="LOGOFF" ;;
        *) action="UNKNOWN" ;;
    esac
    echo "$time | $action | $username | Type:$logontype"
done

EOF

chmod +x timeline_analysis.sh
./timeline_analysis.sh
