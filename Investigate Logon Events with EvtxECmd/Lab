fi

echo "1. Total Events:"
tail -n +2 logon_events.csv | wc -l

echo
echo "2. Successful Logons (Event ID 4624):"
grep "4624" logon_events.csv | wc -l

echo
echo "3. Failed Logons (Event ID 4625):"
grep "4625" logon_events.csv | wc -l

echo
echo "4. Logoffs (Event ID 4634):"
grep "4634" logon_events.csv | wc -l

echo
echo "5. Failed Logon Details:"
grep "4625" logon_events.csv | cut -d',' -f1,7 | head -5

