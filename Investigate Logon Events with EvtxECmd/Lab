EOF

chmod +x analyze_logons.sh
./analyze_logons.sh
Subtask 3.3: Detect Suspicious Patterns
Create a suspicious activity detector:

cat > detect_suspicious.sh << 'EOF'
#!/bin/bash

echo "=== Suspicious Activity Detection ==="
echo

# Check for multiple failed logons from same user
echo "1. Users with Multiple Failed Logons:"
grep "4625" logon_events.csv | cut -d',' -f7 | sort | uniq -c | sort -nr | head -5

echo
echo "2. Unusual Logon Times (assuming business hours 8-18):"
grep "4624" logon_events.csv | while IFS=',' read -r time event level keywords channel computer userid username logontype status; do
    hour=$(echo "$time" | cut -d' ' -f2 | cut -d':' -f1)
    if [ "$hour" -lt 8 ] || [ "$hour" -gt 18 ]; then
        echo "Off-hours logon: $time - $username"
    fi
done

echo
echo "3. Administrative Logons (Type 2 - Interactive):"
grep "4624" logon_events.csv | grep ",2," | cut -d',' -f1,7

echo
echo "4. Remote Logons (Type 10 - RemoteInteractive):"
grep "4624" logon_events.csv | grep ",10," | cut -d',' -f1,7

EOF

chmod +x detect_suspicious.sh
./detect_suspicious.sh
