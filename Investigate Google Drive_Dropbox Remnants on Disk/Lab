#!/usr/bin/env python3
import os
import sqlite3
import hashlib
import json

def extract_file_hashes(directory):
    """Extract file hashes for integrity verification"""
    print(f"\nFile Hash Analysis for: {directory}")
    print("-" * 40)
    
    for root, dirs, files in os.walk(directory):
        for file in files:
            file_path = os.path.join(root, file)
            try:
                with open(file_path, 'rb') as f:
                    content = f.read()
                    md5_hash = hashlib.md5(content).hexdigest()
                    sha256_hash = hashlib.sha256(content).hexdigest()
                
                print(f"File: {file_path}")
                print(f"  MD5: {md5_hash}")
                print(f"  SHA256: {sha256_hash}")
                print(f"  Size: {len(content)} bytes")
                print()
            except Exception as e:
                print(f"Error processing {file_path}: {e}")

def analyze_database_structure(db_path):
    """Analyze database structure and content"""
    print(f"\nDatabase Structure Analysis: {db_path}")
    print("-" * 40)
    
    try:
        conn = sqlite3.connect(db_path)
        cursor = conn.cursor()
        
        # Get table names
        cursor.execute("SELECT name FROM sqlite_master WHERE type='table';")
        tables = cursor.fetchall()
        
        print("Tables found:")
        for table in tables:
            table_name = table[0]
            print(f"  - {table_name}")
            
            # Get table schema
            cursor.execute(f"PRAGMA table_info({table_name});")
            columns = cursor.fetchall()
            
            print("    Columns:")
            for col in columns:
                print(f"      {col[1]} ({col[2]})")
            
            # Count records
            cursor.execute(f"SELECT COUNT(*) FROM {table_name};")
            count = cursor.fetchone()[0]
            print(f"    Records: {count}")
            print()
        
        conn.close()
        
    except Exception as e:
        print(f"Error analyzing database: {e}")

def generate_forensic_report():
    """Generate comprehensive forensic report"""
    report = {
        "analysis_timestamp": str(datetime.now()),
        "google_drive_artifacts": {},
        "dropbox_artifacts": {},
        "summary": {}
    }
    
    # Analyze Google Drive
    gdrive_db = "google_drive_artifacts/sync_config.db"
    if os.path.exists(gdrive_db):
        conn = sqlite3.connect(gdrive_db)
        cursor = conn.cursor()
        
        cursor.execute("SELECT COUNT(*) FROM sync_items WHERE sync_status='synced'")
        synced_count = cursor.fetchone()[0]
        
        cursor.execute("SELECT COUNT(*) FROM sync_items WHERE sync_status='deleted'")
        deleted_count = cursor.fetchone()[0]
        
        cursor.execute("SELECT COUNT(*) FROM deleted_items")
        total_deleted = cursor.fetchone()[0]
        
        report["google_drive_artifacts"] = {
            "synced_files": synced_count,
            "deleted_files": deleted_count,
            "total_deletions": total_deleted
        }
        
        conn.close()
    
    # Analyze Dropbox
    dropbox_db = "dropbox_artifacts/.dropbox/dropbox.db"
    if os.path.exists(dropbox_db):
        conn = sqlite3.connect(dropbox_db)
        cursor = conn.cursor()
        
        cursor.execute("SELECT COUNT(*) FROM file_journal WHERE operation='upload'")
        uploads = cursor.fetchone()[0]
        
        cursor.execute("SELECT COUNT(*) FROM file_journal WHERE operation='download'")
        downloads = cursor.fetchone()[0]
        
        cursor.execute("SELECT COUNT(*) FROM file_journal WHERE operation='delete'")
        deletions = cursor.fetchone()[0]
        
        cursor.execute("SELECT SUM(bytes_transferred) FROM sync_history WHERE action LIKE '%UPLOAD%'")
        total_uploaded = cursor.fetchone()[0] or 0
        
        report["dropbox_artifacts"] = {
            "uploads": uploads,
            "downloads": downloads,
            "deletions": deletions,
            "total_uploaded_bytes": total_uploaded
        }
        
        conn.close()
    
    # Generate summary
    total_files = report.get("google_drive_artifacts", {}).get("synced_files", 0) + \
                  report.get("dropbox_artifacts", {}).get("uploads", 0)
    
    total_deletions = report.get("google_drive_artifacts", {}).get("total_deletions", 0) + \
                      report.get("dropbox_artifacts", {}).get("deletions", 0)
    
    report["summary"] = {
        "total_files_processed": total_files,
        "total_deletions": total_deletions,
        "evidence_significance": "HIGH" if total_deletions > 0 else "MEDIUM"
    }
    
    # Save report
    with open("forensic_report.json", "w") as f:
        json.dump(report, f, indent=2)
    
    print("FORENSIC ANALYSIS REPORT")
    print("=" * 40)
    print(json.dumps(report, indent=2))

if __name__ == "__main__":
    from datetime import datetime
    
    # Extract file hashes
    extract_file_hashes("google_drive_artifacts")
    extract_file_hashes("dropbox_artifacts")
    
    # Analyze databases
    if os.path.exists("google_drive_artifacts/sync_config.db"):
        analyze_database_structure("google_drive_artifacts/sync_config.db")
    
    if os.path.exists("dropbox_artifacts/.dropbox/dropbox.db"):
        analyze_database_structure("dropbox_artifacts/.dropbox/dropbox.db")
    
    # Generate report
    generate_forensic_report()
EOF

