#!/usr/bin/env python3
import sqlite3
import os
import re
from datetime import datetime

def analyze_dropbox_db(db_path):
    print("Dropbox Forensic Analysis")
    print("=" * 40)
    
    try:
        conn = sqlite3.connect(db_path)
        cursor = conn.cursor()
        
        # Analyze file journal
        print("\n1. FILE JOURNAL ANALYSIS:")
        cursor.execute("SELECT server_path, local_path, sync_time, operation, file_hash FROM file_journal ORDER BY sync_time DESC")
        for row in cursor.fetchall():
            server_path, local_path, sync_time, operation, file_hash = row
            print(f"   Server Path: {server_path}")
            print(f"   Local Path: {local_path}")
            print(f"   Operation: {operation}")
            print(f"   Sync Time: {sync_time}")
            print(f"   File Hash: {file_hash}")
            print()
        
        # Analyze sync history
        print("2. SYNC HISTORY ANALYSIS:")
        cursor.execute("SELECT timestamp, action, file_path, bytes_transferred FROM sync_history ORDER BY timestamp DESC")
        total_uploaded = 0
        total_downloaded = 0
        
        for row in cursor.fetchall():
            timestamp, action, file_path, bytes_transferred = row
            bytes_mb = bytes_transferred / (1024*1024) if bytes_transferred else 0
            print(f"   Time: {timestamp}")
            print(f"   Action: {action}")
            print(f"   File: {file_path}")
            print(f"   Data: {bytes_mb:.2f} MB")
            
            if 'UPLOAD' in action:
                total_uploaded += bytes_transferred
            elif 'DOWNLOAD' in action:
                total_downloaded += bytes_transferred
            print()
        
        print("3. TRAFFIC SUMMARY:")
        print(f"   Total Uploaded: {total_uploaded/(1024*1024):.2f} MB")
        print(f"   Total Downloaded: {total_downloaded/(1024*1024):.2f} MB")
        
        conn.close()
        
    except Exception as e:
        print(f"Error analyzing database: {e}")

def analyze_dropbox_logs(log_path):
    print("\n4. LOG FILE ANALYSIS:")
    if os.path.exists(log_path):
        with open(log_path, 'r') as f:
            lines = f.readlines()
            
        upload_count = 0
        download_count = 0
        delete_count = 0
        
        for line in lines:
            if 'Upload' in line:
                upload_count += 1
                print(f"   UPLOAD: {line.strip()}")
            elif 'Download' in line:
                download_count += 1
                print(f"   DOWNLOAD: {line.strip()}")
            elif 'Delet' in line:
                delete_count += 1
                print(f"   DELETE: {line.strip()}")
        
        print(f"\n   Summary: {upload_count} uploads, {download_count} downloads, {delete_count} deletions")
    else:
        print("   Log file not found!")

if __name__ == "__main__":
    db_path = "dropbox_artifacts/.dropbox/dropbox.db"
    log_path = "dropbox_artifacts/.dropbox/logs/sync.log"
    
    if os.path.exists(db_path):
        analyze_dropbox_db(db_path)
    else:
        print("Dropbox database not found!")
    
    analyze_dropbox_logs(log_path)
