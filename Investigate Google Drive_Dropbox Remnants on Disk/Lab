#!/usr/bin/env python3
import sqlite3
import os
import re
from datetime import datetime

def create_timeline():
    print("Cloud Storage Activity Timeline")
    print("=" * 50)
    
    events = []
    
    # Extract Google Drive events
    gdrive_db = "google_drive_artifacts/sync_config.db"
    if os.path.exists(gdrive_db):
        conn = sqlite3.connect(gdrive_db)
        cursor = conn.cursor()
        
        # Sync events
        cursor.execute("SELECT local_path, last_sync, sync_status FROM sync_items")
        for row in cursor.fetchall():
            path, sync_time, status = row
            events.append((sync_time, f"GDRIVE_SYNC", f"{status}: {path}"))
        
        # Deletion events
        cursor.execute("SELECT original_path, deletion_time FROM deleted_items")
        for row in cursor.fetchall():
            path, del_time = row
            events.append((del_time, f"GDRIVE_DELETE", f"deleted: {path}"))
        
        conn.close()
    
    # Extract Dropbox events
    dropbox_db = "dropbox_artifacts/.dropbox/dropbox.db"
    if os.path.exists(dropbox_db):
        conn = sqlite3.connect(dropbox_db)
        cursor = conn.cursor()
        
        cursor.execute("SELECT timestamp, action, file_path FROM sync_history")
        for row in cursor.fetchall():
            timestamp, action, file_path = row
            events.append((timestamp, f"DROPBOX_{action}", file_path))
        
        conn.close()
    
    # Sort events by timestamp
    events.sort(key=lambda x: x[0])
    
    print("\nCHRONOLOGICAL ACTIVITY:")
    for timestamp, event_type, details in events:
        print(f"{timestamp} | {event_type:20} | {details}")
    
    return events

def analyze_patterns(events):
    print("\n" + "=" * 50)
    print("PATTERN ANALYSIS:")
    
    # Count event types
    event_counts = {}
    for _, event_type, _ in events:
        event_counts[event_type] = event_counts.get(event_type, 0) + 1
    
    print("\nEvent Distribution:")
    for event_type, count in sorted(event_counts.items()):
        print(f"   {event_type}: {count} occurrences")
    
    # Identify suspicious patterns
    print("\nSuspicious Activity Indicators:")
    
    deletion_events = [e for e in events if 'DELETE' in e[1]]
    if len(deletion_events) > 0:
        print(f"   - {len(deletion_events)} deletion events detected")
        for timestamp, event_type, details in deletion_events:
            print(f"     {timestamp}: {details}")
    
    # Check for rapid sync activity
    sync_events = [e for e in events if 'SYNC' in e[1] or 'UPLOAD' in e[1] or 'DOWNLOAD' in e[1]]
    if len(sync_events) > 3:
        print(f"   - High sync activity: {len(sync_events)} sync operations")

if __name__ == "__main__":
    events = create_timeline()
    analyze_patterns(events)
EOF

