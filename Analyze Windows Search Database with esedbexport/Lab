#!/usr/bin/env python3
import csv
import os
from datetime import datetime
from collections import defaultdict

def create_timeline(csv_file):
    """Create a timeline of file activity from Windows Search data"""
    
    if not os.path.exists(csv_file):
        print(f"File {csv_file} not found")
        return
    
    print("=== File Activity Timeline ===")
    
    timeline = []
    
    with open(csv_file, 'r', encoding='utf-8', errors='ignore') as f:
        reader = csv.DictReader(f)
        for row in reader:
            modified = row.get('DateModified', '')
            filename = row.get('FileName', '')
            path = row.get('Path', '')
            size = row.get('Size', '0')
            
            if modified and filename:
                timeline.append({
                    'timestamp': modified,
                    'filename': filename,
                    'path': path,
                    'size': size,
                    'action': 'Modified'
                })
    
    # Sort by timestamp
    timeline.sort(key=lambda x: x['timestamp'])
    
    # Display timeline
    print(f"Timeline entries: {len(timeline)}")
    print("\nRecent Activity (Last 10 entries):")
    print("-" * 80)
    
    for entry in timeline[-10:]:
        print(f"Time: {entry['timestamp']}")
        print(f"Action: {entry['action']}")
        print(f"File: {entry['filename']}")
        print(f"Path: {entry['path']}")
        print(f"Size: {entry['size']} bytes")
        print("-" * 40)
    
    # Activity by day
    daily_activity = defaultdict(int)
    for entry in timeline:
        try:
            date = entry['timestamp'].split(' ')[0]
            daily_activity[date] += 1
        except:
            pass
    
    print(f"\n=== Daily Activity Summary ===")
    for date, count in sorted(daily_activity.items())[-7:]:  # Last 7 days
        print(f"{date}: {count} file modifications")

if __name__ == "__main__":
    create_timeline("extracted_data/SystemIndex_0A.csv")
EOF

