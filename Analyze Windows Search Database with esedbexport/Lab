#!/usr/bin/env python3
import csv
import re
import os

def search_artifacts(csv_file, search_terms):
    """Search for specific artifacts in the Windows Search database"""
    
    if not os.path.exists(csv_file):
        print(f"File {csv_file} not found")
        return
    
    print("=== Forensic Artifact Search ===")
    
    findings = []
    
    with open(csv_file, 'r', encoding='utf-8', errors='ignore') as f:
        reader = csv.DictReader(f)
        for row in reader:
            filename = row.get('FileName', '').lower()
            path = row.get('Path', '').lower()
            title = row.get('Title', '').lower()
            
            # Search for terms
            for term in search_terms:
                if (term.lower() in filename or 
                    term.lower() in path or 
                    term.lower() in title):
                    
                    findings.append({
                        'term': term,
                        'filename': row.get('FileName', ''),
                        'path': row.get('Path', ''),
                        'size': row.get('Size', ''),
                        'modified': row.get('DateModified', ''),
                        'title': row.get('Title', '')
                    })
    
    # Display findings
    for finding in findings:
        print(f"\nFound: '{finding['term']}'")
        print(f"File: {finding['filename']}")
        print(f"Path: {finding['path']}")
        print(f"Title: {finding['title']}")
        print(f"Size: {finding['size']} bytes")
        print(f"Modified: {finding['modified']}")
        print("-" * 50)
    
    print(f"\nTotal artifacts found: {len(findings)}")

def analyze_user_activity(csv_file):
    """Analyze user activity patterns"""
    
    if not os.path.exists(csv_file):
        return
    
    print("\n=== User Activity Analysis ===")
    
    paths = {}
    authors = {}
    
    with open(csv_file, 'r', encoding='utf-8', errors='ignore') as f:
        reader = csv.DictReader(f)
        for row in reader:
            # Analyze paths for user activity
            path = row.get('Path', '')
            if 'Users' in path:
                user_path = path.split('Users')[1].split('\\')[1] if '\\' in path.split('Users')[1] else 'Unknown'
                paths[user_path] = paths.get(user_path, 0) + 1
            
            # Analyze authors
            author = row.get('Author', '').strip()
            if author:
                authors[author] = authors.get(author, 0) + 1
    
    print("User Activity by Path:")
    for user, count in sorted(paths.items(), key=lambda x: x[1], reverse=True):
        print(f"  {user}: {count} files")
    
    print("\nDocument Authors:")
    for author, count in sorted(authors.items(), key=lambda x: x[1], reverse=True)[:10]:
        print(f"  {author}: {count} documents")

if __name__ == "__main__":
    # Define search terms for forensic analysis
    search_terms = [
        "password", "confidential", "secret", "private",
        "budget", "financial", "report", "presentation"
    ]
    
    search_artifacts("extracted_data/SystemIndex_0A.csv", search_terms)
    analyze_user_activity("extracted_data/SystemIndex_0A.csv")
EOF

