#!/usr/bin/env python3
import csv
import os
from datetime import datetime

def analyze_search_index(csv_file):
    if not os.path.exists(csv_file):
        print(f"File {csv_file} not found")
        return
    
    print(f"Analyzing {csv_file}...")
    
    file_types = {}
    total_size = 0
    recent_files = []
    
    with open(csv_file, 'r', encoding='utf-8', errors='ignore') as f:
        reader = csv.DictReader(f)
        for row in reader:
            # Count file types
            ext = row.get('FileExtension', '').lower()
            file_types[ext] = file_types.get(ext, 0) + 1
            
            # Calculate total size
            try:
                size = int(row.get('Size', 0))
                total_size += size
            except:
                pass
            
            # Track recent files
            recent_files.append({
                'name': row.get('FileName', ''),
                'path': row.get('Path', ''),
                'modified': row.get('DateModified', ''),
                'size': row.get('Size', 0)
            })
    
    print(f"\n=== File Type Distribution ===")
    for ext, count in sorted(file_types.items(), key=lambda x: x[1], reverse=True):
        print(f"{ext or 'No extension'}: {count} files")
    
    print(f"\nTotal indexed size: {total_size:,} bytes ({total_size/1024/1024:.2f} MB)")
    
    print(f"\n=== Recent Files (Last 5) ===")
    for file_info in recent_files[-5:]:
        print(f"File: {file_info['name']}")
        print(f"Path: {file_info['path']}")
        print(f"Modified: {file_info['modified']}")
        print(f"Size: {file_info['size']} bytes")
        print("-" * 40)

if __name__ == "__main__":
    analyze_search_index("extracted_data/SystemIndex_0A.csv")
EOF

