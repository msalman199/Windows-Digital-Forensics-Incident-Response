Subtask 2.2: Extract Network Usage Data
Create a script to extract network usage patterns:

cat > extract_network_usage.py << 'EOF'
import sqlite3
import csv
from datetime import datetime

def extract_network_usage(db_path):
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    
    # Get application mappings
    app_map = {}
    cursor.execute("SELECT IdIndex, IdBlob FROM SruDbIdMapTable WHERE IdType = 3")
    for row in cursor.fetchall():
        app_map[row[0]] = row[1].decode('utf-8', errors='ignore').rstrip('\x00')
    
    # Extract network usage data
    query = '''
    SELECT TimeStamp, AppId, BytesSent, BytesRecvd, InterfaceLuid
    FROM "{D10CA2FE-6FCF-4F6D-848E-B2E99266FA89}"
    ORDER BY TimeStamp DESC
    '''
    
    cursor.execute(query)
    results = cursor.fetchall()
    
    # Write to CSV
    with open('network_usage.csv', 'w', newline='') as csvfile:
        writer = csv.writer(csvfile)
        writer.writerow(['Timestamp', 'Application', 'Bytes Sent', 'Bytes Received', 'Interface', 'Total Traffic'])
        
        for row in results:
            timestamp, app_id, bytes_sent, bytes_recv, interface = row
            app_name = app_map.get(app_id, f'Unknown App ID {app_id}')
            total_traffic = bytes_sent + bytes_recv
            
            writer.writerow([timestamp, app_name, bytes_sent, bytes_recv, interface, total_traffic])
    
    conn.close()
    print(f"Network usage data extracted to network_usage.csv ({len(results)} records)")
    
    # Display top network consumers
    print("\nTop Network Consumers:")
    app_totals = {}
    for row in results:
        app_id = row[1]
        app_name = app_map.get(app_id, f'Unknown App ID {app_id}')
        total = row[2] + row[3]  # bytes_sent + bytes_recv
        app_totals[app_name] = app_totals.get(app_name, 0) + total
    
    for app, total in sorted(app_totals.items(), key=lambda x: x[1], reverse=True)[:5]:
        print(f"  {app}: {total:,} bytes")

if __name__ == "__main__":
    extract_network_usage('SRUDB.dat')
EOF

