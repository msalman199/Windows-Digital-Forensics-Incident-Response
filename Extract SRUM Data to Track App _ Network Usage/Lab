import sqlite3
from collections import defaultdict
import json

def generate_statistics(db_path):
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    
    # Get application mappings
    app_map = {}
    cursor.execute("SELECT IdIndex, IdBlob FROM SruDbIdMapTable WHERE IdType = 3")
    for row in cursor.fetchall():
        app_map[row[0]] = row[1].decode('utf-8', errors='ignore').rstrip('\x00')
    
    stats = {
        'network_stats': defaultdict(lambda: {'bytes_sent': 0, 'bytes_received': 0, 'sessions': 0}),
        'app_stats': defaultdict(lambda: {'total_cpu_time': 0, 'foreground_time': 0, 'sessions': 0}),
        'summary': {}
    }
    
    # Network statistics
    cursor.execute('''
    SELECT AppId, SUM(BytesSent), SUM(BytesRecvd), COUNT(*)
    FROM "{D10CA2FE-6FCF-4F6D-848E-B2E99266FA89}"
    GROUP BY AppId
    ''')
    
    total_network_traffic = 0
    for row in cursor.fetchall():
        app_id, bytes_sent, bytes_recv, sessions = row
        app_name = app_map.get(app_id, f'Unknown App ID {app_id}')
        stats['network_stats'][app_name]['bytes_sent'] = bytes_sent
        stats['network_stats'][app_name]['bytes_received'] = bytes_recv
        stats['network_stats'][app_name]['sessions'] = sessions
        total_network_traffic += bytes_sent + bytes_recv
    
    # Application statistics
    cursor.execute('''
    SELECT AppId, SUM(ForegroundCycleTime + BackgroundCycleTime), 
           SUM(ForegroundCycleTime), COUNT(*)
    FROM "{D10CA2FE-6FCF-4F6D-848E-B2E99266FA86}"
    GROUP BY AppId
    ''')
    
    total_cpu_time = 0
    for row in cursor.fetchall():
        app_id, total_cpu, fg_time, sessions = row
        app_name = app_map.get(app_id, f'Unknown App ID {app_id}')
        stats['app_stats'][app_name]['total_cpu_time'] = total_cpu
        stats['app_stats'][app_name]['foreground_time'] = fg_time
        stats['app_stats'][app_name]['sessions'] = sessions
        total_cpu_time += total_cpu
    
    # Summary statistics
    stats['summary'] = {
        'total_applications': len(app_map),
        'total_network_traffic_bytes': total_network_traffic,
        'total_cpu_time_ms': total_cpu_time,
        'most_network_intensive': max(stats['network_stats'].items(), 
                                    key=lambda x: x[1]['bytes_sent'] + x[1]['bytes_received'])[0] if stats['network_stats'] else 'None',
        'most_cpu_intensive': max(stats['app_stats'].items(), 
                                key=lambda x: x[1]['total_cpu_time'])[0] if stats['app_stats'] else 'None'
    }
    
    # Save to JSON
    with open('usage_statistics.json', 'w') as f:
        json.dump(stats, f, indent=2, default=str)
    
    conn.close()
    
    # Display summary
    print("SRUM Usage Statistics Summary")
    print("=" * 40)
    print(f"Total Applications Tracked: {stats['summary']['total_applications']}")
    print(f"Total Network Traffic: {stats['summary']['total_network_traffic_bytes']:,} bytes")
    print(f"Total CPU Time: {stats['summary']['total_cpu_time_ms']:,} ms")
    print(f"Most Network Intensive App: {stats['summary']['most_network_intensive']}")
    print(f"Most CPU Intensive App: {stats['summary']['most_cpu_intensive']}")
    
    print("\nTop 3 Network Users:")
    network_sorted = sorted(stats['network_stats'].items(), 
                          key=lambda x: x[1]['bytes_sent'] + x[1]['bytes_received'], 
                          reverse=True)[:3]
    for app, data in network_sorted:
        total_traffic = data['bytes_sent'] + data['bytes_received']
        print(f"  {app}: {total_traffic:,} bytes ({data['sessions']} sessions)")
    
    print("\nTop 3 CPU Users:")
    cpu_sorted = sorted(stats['app_stats'].items(), 
                       key=lambda x: x[1]['total_cpu_time'], 
                       reverse=True)[:3]
    for app, data in cpu_sorted:
        print(f"  {app}: {data['total_cpu_time']:,} ms ({data['sessions']} sessions)")

if __name__ == "__main__":
    generate_statistics('SRUDB.dat')
EOF

