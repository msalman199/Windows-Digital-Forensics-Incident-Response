import sqlite3
import csv
from datetime import datetime
from collections import defaultdict

def create_timeline(db_path):
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    
    # Get application mappings
    app_map = {}
    cursor.execute("SELECT IdIndex, IdBlob FROM SruDbIdMapTable WHERE IdType = 3")
    for row in cursor.fetchall():
        app_map[row[0]] = row[1].decode('utf-8', errors='ignore').rstrip('\x00')
    
    timeline_events = []
    
    # Get network events
    cursor.execute('''
    SELECT TimeStamp, AppId, BytesSent, BytesRecvd
    FROM "{D10CA2FE-6FCF-4F6D-848E-B2E99266FA89}"
    WHERE BytesSent > 0 OR BytesRecvd > 0
    ''')
    
    for row in cursor.fetchall():
        timestamp, app_id, bytes_sent, bytes_recv = row
        app_name = app_map.get(app_id, f'Unknown App ID {app_id}')
        timeline_events.append({
            'timestamp': timestamp,
            'type': 'Network Activity',
            'application': app_name,
            'details': f'Sent: {bytes_sent} bytes, Received: {bytes_recv} bytes'
        })
    
    # Get application events
    cursor.execute('''
    SELECT TimeStamp, AppId, ForegroundCycleTime, FaceTime
    FROM "{D10CA2FE-6FCF-4F6D-848E-B2E99266FA86}"
    WHERE ForegroundCycleTime > 0
    ''')
    
    for row in cursor.fetchall():
        timestamp, app_id, fg_time, face_time = row
        app_name = app_map.get(app_id, f'Unknown App ID {app_id}')
        timeline_events.append({
            'timestamp': timestamp,
            'type': 'Application Usage',
            'application': app_name,
            'details': f'Foreground: {fg_time} ms, Face time: {face_time} ms'
        })
    
    # Sort by timestamp
    timeline_events.sort(key=lambda x: x['timestamp'])
    
    # Write timeline to CSV
    with open('activity_timeline.csv', 'w', newline='') as csvfile:
        writer = csv.writer(csvfile)
        writer.writerow(['Timestamp', 'Event Type', 'Application', 'Details'])
        
        for event in timeline_events:
            writer.writerow([event['timestamp'], event['type'], 
                           event['application'], event['details']])
    
    conn.close()
    print(f"Activity timeline created with {len(timeline_events)} events")
    
    # Show recent activity
    print("\nRecent Activity (last 10 events):")
    for event in timeline_events[-10:]:
        print(f"  {event['timestamp']} - {event['type']}: {event['application']}")

if __name__ == "__main__":
    create_timeline('SRUDB.dat')
EOF

