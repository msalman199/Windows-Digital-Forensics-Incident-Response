Subtask 1.3: Create Event Log Parser
Create a Python script to parse Windows event logs:

cat > parse_events.py << 'EOF'
#!/usr/bin/env python3
import xml.etree.ElementTree as ET
import pandas as pd
from datetime import datetime
import sys

def parse_event_log(xml_file):
    events = []
    
    try:
        tree = ET.parse(xml_file)
        root = tree.getroot()
        
        for event in root.findall('Event'):
            event_data = {}
            
            # Extract System information
            system = event.find('System')
            if system is not None:
                event_id = system.find('EventID')
                time_created = system.find('TimeCreated')
                computer = system.find('Computer')
                
                event_data['EventID'] = event_id.text if event_id is not None else 'Unknown'
                event_data['TimeCreated'] = time_created.get('SystemTime') if time_created is not None else 'Unknown'
                event_data['Computer'] = computer.text if computer is not None else 'Unknown'
            
            # Extract EventData
            event_data_elem = event.find('EventData')
            if event_data_elem is not None:
                for data in event_data_elem.findall('Data'):
                    name = data.get('Name')
                    value = data.text if data.text else ''
                    event_data[name] = value
            
            events.append(event_data)
    
    except Exception as e:
        print(f"Error parsing XML: {e}")
        return []
    
    return events

def categorize_event(event_id):
    categories = {
        '4624': 'Successful Logon',
        '4625': 'Failed Logon',
        '4634': 'Logoff',
        '4647': 'User Initiated Logoff',
        '4648': 'Explicit Credential Use',
        '4672': 'Special Privileges Assigned',
        '4776': 'Domain Controller Authentication',
        '4778': 'Session Reconnected',
        '4779': 'Session Disconnected'
    }
    return categories.get(event_id, 'Other')

def main():
    if len(sys.argv) != 2:
        print("Usage: python3 parse_events.py <xml_file>")
        sys.exit(1)
    
    xml_file = sys.argv[1]
    events = parse_event_log(xml_file)
    
    if not events:
        print("No events found or error parsing file")
        return
    
    # Convert to DataFrame for easier analysis
    df = pd.DataFrame(events)
    
    # Add event category
    df['Category'] = df['EventID'].apply(categorize_event)
    
    # Sort by time
    df['TimeCreated'] = pd.to_datetime(df['TimeCreated'])
    df = df.sort_values('TimeCreated')
    
    # Save to CSV
    output_file = 'parsed_events.csv'
    df.to_csv(output_file, index=False)
    print(f"Parsed {len(events)} events and saved to {output_file}")
    
    # Display summary
    print("\nEvent Summary:")
    print(df['Category'].value_counts())
    
    return df

if __name__ == "__main__":
    main()
EOF

