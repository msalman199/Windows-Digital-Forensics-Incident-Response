#!/usr/bin/env python3
import pandas as pd
from datetime import datetime
import sys

def generate_investigation_report(csv_file):
    df = pd.read_csv(csv_file)
    df['TimeCreated'] = pd.to_datetime(df['TimeCreated'])
    
    report_time = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
    
    report = f"""
INSIDER THREAT INVESTIGATION REPORT
Generated: {report_time}
Data Source: {csv_file}

{'='*60}
EXECUTIVE SUMMARY
{'='*60}

This report analyzes Windows Security Event Logs to identify potential
insider threat activities. The analysis covers logon/logoff events,
failed authentication attempts, and privilege escalation indicators.

Analysis Period: {df['TimeCreated'].min()} to {df['TimeCreated'].max()}
Total Events: {len(df)}
Unique Users: {len(df['TargetUserName'].dropna().unique())}
Unique Systems: {len(df['Computer'].dropna().unique())}

{'='*60}
KEY FINDINGS
{'='*60}

"""
    
    # Analyze findings
    findings = []
    
    # Failed logins
    failed_logins = df[df['EventID'] == '4625']
    if not failed_logins.empty:
        findings.append(f"• {len(failed_logins)} failed login attempts detected")
        for _, event in failed_logins.iterrows():
            findings.append(f"  - {event['TimeCreated']}: User '{event.get('TargetUserName', 'Unknown')}' from IP {event.get('IpAddress', 'Unknown')}")
    
    # Privilege escalation
    priv_events = df[df['EventID'] == '4648']
    if not priv_events.empty:
        findings.append(f"• {len(priv_events)} explicit credential use events (potential privilege escalation)")
        for _, event in priv_events.iterrows():
            findings.append(f"  - {event['TimeCreated']}: {event.get('SubjectUserName', 'Unknown')} -> {event.get('TargetUserName', 'Unknown')}")
    
    # Off-hours activity
    df['Hour'] = df['TimeCreated'].dt.hour
    off_hours = df[(df['Hour'] < 7) | (df['Hour'] > 19)]
    if not off_hours.empty:
        findings.append(f"• {len(off_hours)} off-hours activities detected")
        for _, event in off_hours.iterrows():
            findings.append(f"  - {event['TimeCreated']}: {event['Category']} by {event.get('TargetUserName', 'Unknown')}")
    
    if not findings:
        findings.append("• No suspicious activities detected in the analyzed timeframe")
    
    report += "\n".join(findings)
    
    report += f"""

{'='*60}
DETAILED EVENT BREAKDOWN
{'='*60}

Event Type Distribution:
"""
    
    for category, count in df['Category'].value_counts().items():
        report += f"• {category}: {count} events\n"
    
    report += f"""
{'='*60}
RECOMMENDATIONS
{'='*60}

Based on the analysis, the following actions are recommended:

1. IMMEDIATE ACTIONS:
   • Review all failed login attempts for potential brute force attacks
   • Investigate off-hours activities for unauthorized access
   • Verify all privilege escalation events with users

2. ONGOING MONITORING:
   • Implement real-time alerting for failed login attempts
   • Monitor off-hours access patterns
   • Track privilege escalation events
   • Establish baseline user behavior patterns

3. SECURITY ENHANCEMENTS:
   • Implement multi-factor authentication
