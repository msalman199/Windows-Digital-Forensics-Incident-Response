#!/usr/bin/env python3
import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.dates as mdates
from datetime import datetime
import sys

def create_visual_timeline(csv_file):
    # Read the data
    df = pd.read_csv(csv_file)
    df['TimeCreated'] = pd.to_datetime(df['TimeCreated'])
    
    # Create figure and axis
    fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(15, 10))
    
    # Timeline plot
    event_colors = {
        'Successful Logon': 'green',
        'Failed Logon': 'red',
        'Logoff': 'blue',
        'Explicit Credential Use': 'orange',
        'Other': 'gray'
    }
    
    for category in df['Category'].unique():
        category_data = df[df['Category'] == category]
        ax1.scatter(category_data['TimeCreated'], 
                   [category] * len(category_data),
                   c=event_colors.get(category, 'gray'),
                   s=100, alpha=0.7, label=category)
    
    ax1.set_xlabel('Time')
    ax1.set_ylabel('Event Type')
    ax1.set_title('Event Timeline')
    ax1.legend()
    ax1.grid(True, alpha=0.3)
    
    # Format x-axis
    ax1.xaxis.set_major_formatter(mdates.DateFormatter('%H:%M'))
    ax1.xaxis.set_major_locator(mdates.HourLocator(interval=2))
    plt.setp(ax1.xaxis.get_majorticklabels(), rotation=45)
    
    # Event count by hour
    df['Hour'] = df['TimeCreated'].dt.hour
    hourly_counts = df.groupby('Hour').size()
    
    ax2.bar(hourly_counts.index, hourly_counts.values, alpha=0.7, color='skyblue')
    ax2.set_xlabel('Hour of Day')
    ax2.set_ylabel('Event Count')
    ax2.set_title('Event Distribution by Hour')
    ax2.grid(True, alpha=0.3)
    ax2.set_xticks(range(0, 24, 2))
    
    plt.tight_layout()
    plt.savefig('timeline_analysis.png', dpi=300, bbox_inches='tight')
    print("Visual timeline saved as 'timeline_analysis.png'")
    
    # Show the plot (if display is available)
    try:
        plt.show()
    except:
        print("Display not available, but chart saved to file.")

if __name__ == "__main__":
    if len(sys.argv) != 2:
        print("Usage: python3 visual_timeline.py <csv_file>")
        sys.exit(1)
    
    create_visual_timeline(sys.argv[1])
