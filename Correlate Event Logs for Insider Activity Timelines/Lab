#!/usr/bin/env python3
import pandas as pd
import matplotlib.pyplot as plt
from datetime import datetime, timedelta
import sys

class InsiderActivityAnalyzer:
    def __init__(self, csv_file):
        self.df = pd.read_csv(csv_file)
        self.df['TimeCreated'] = pd.to_datetime(self.df['TimeCreated'])
        
    def create_user_timeline(self, username=None):
        """Create timeline for specific user or all users"""
        if username:
            user_events = self.df[self.df['TargetUserName'] == username].copy()
            print(f"\nTimeline for user: {username}")
        else:
            user_events = self.df.copy()
            print("\nTimeline for all users:")
        
        user_events = user_events.sort_values('TimeCreated')
        
        print("-" * 80)
        print(f"{'Time':<20} {'Event':<20} {'User':<15} {'Details':<25}")
        print("-" * 80)
        
        for _, event in user_events.iterrows():
            time_str = event['TimeCreated'].strftime('%Y-%m-%d %H:%M:%S')
            category = event['Category']
            user = event.get('TargetUserName', 'N/A')
            
            # Build details string
            details = []
            if 'LogonType' in event and pd.notna(event['LogonType']):
                logon_types = {
                    '2': 'Interactive',
                    '3': 'Network',
                    '4': 'Batch',
                    '5': 'Service',
                    '7': 'Unlock',
                    '8': 'NetworkCleartext',
                    '9': 'NewCredentials',
                    '10': 'RemoteInteractive',
                    '11': 'CachedInteractive'
                }
                details.append(f"Type:{logon_types.get(str(int(event['LogonType'])), 'Unknown')}")
            
            if 'IpAddress' in event and pd.notna(event['IpAddress']) and event['IpAddress'] != '-':
                details.append(f"IP:{event['IpAddress']}")
            
            if 'Computer' in event and pd.notna(event['Computer']):
                details.append(f"Host:{event['Computer']}")
            
            details_str = " | ".join(details)[:25]
            
            print(f"{time_str:<20} {category:<20} {user:<15} {details_str:<25}")
    
    def detect_suspicious_patterns(self):
        """Detect potentially suspicious insider activity patterns"""
        print("\n" + "="*60)
        print("SUSPICIOUS ACTIVITY ANALYSIS")
        print("="*60)
        
        # Pattern 1: Failed login attempts
        failed_logins = self.df[self.df['EventID'] == '4625']
        if not failed_logins.empty:
            print(f"\n1. Failed Login Attempts: {len(failed_logins)}")
            for _, event in failed_logins.iterrows():
                time_str = event['TimeCreated'].strftime('%Y-%m-%d %H:%M:%S')
                user = event.get('TargetUserName', 'Unknown')
                ip = event.get('IpAddress', 'Unknown')
                print(f"   {time_str} - User: {user}, IP: {ip}")
        
        # Pattern 2: Privilege escalation attempts
        priv_events = self.df[self.df['EventID'] == '4648']
        if not priv_events.empty:
            print(f"\n2. Explicit Credential Use (Potential Privilege Escalation): {len(priv_events)}")
            for _, event in priv_events.iterrows():
                time_str = event['TimeCreated'].strftime('%Y-%m-%d %H:%M:%S')
                source_user = event.get('SubjectUserName', 'Unknown')
                target_user = event.get('TargetUserName', 'Unknown')
                target_server = event.get('TargetServerName', 'Unknown')
                print(f"   {time_str} - {source_user} -> {target_user} on {target_server}")
        
        # Pattern 3: Off-hours activity
        self.df['Hour'] = self.df['TimeCreated'].dt.hour
        off_hours = self.df[(self.df['Hour'] < 7) | (self.df['Hour'] > 19)]
        if not off_hours.empty:
            print(f"\n3. Off-Hours Activity (Before 7 AM or After 7 PM): {len(off_hours)}")
            for _, event in off_hours.iterrows():
                time_str = event['TimeCreated'].strftime('%Y-%m-%d %H:%M:%S')
                user = event.get('TargetUserName', 'Unknown')
                category = event['Category']
                print(f"   {time_str} - User: {user}, Activity: {category}")
        
        # Pattern 4: Rapid successive logons/logoffs
        logon_events = self.df[self.df['EventID'].isin(['4624', '4634'])].sort_values('TimeCreated')
        if len(logon_events) > 1:
            rapid_events = []
            for i in range(1, len(logon_events)):
                time_diff = (logon_events.iloc[i]['TimeCreated'] - logon_events.iloc[i-1]['TimeCreated']).total_seconds()
                if time_diff < 300:  # Less than 5 minutes
                    rapid_events.append((logon_events.iloc[i-1], logon_events.iloc[i], time_diff))
            
            if rapid_events:
                print(f"\n4. Rapid Logon/Logoff Sequences (< 5 minutes apart): {len(rapid_events)}")
                for prev_event, curr_event, time_diff in rapid_events:
                    prev_time = prev_event['TimeCreated'].strftime('%Y-%m-%d %H:%M:%S')
                    curr_time = curr_event['TimeCreated'].strftime('%Y-%m-%d %H:%M:%S')
                    print(f"   {prev_time} -> {curr_time} ({time_diff:.0f}s apart)")
    
    def generate_summary_report(self):
        """Generate comprehensive summary report"""
        print("\n" + "="*60)
        print("ACTIVITY SUMMARY REPORT")
        print("="*60)
        
        # Time range
        start_time = self.df['TimeCreated'].min()
        end_time = self.df['TimeCreated'].max()
        print(f"Analysis Period: {start_time} to {end_time}")
        
        # Event counts by category
        print(f"\nTotal Events Analyzed: {len(self.df)}")
        print("\nEvent Breakdown:")
        category_counts = self.df['Category'].value_counts()
        for category, count in category_counts.items():
            print(f"  {category}: {count}")
        
        # Unique users
        unique_users = self.df['TargetUserName'].dropna().unique()
        print(f"\nUnique Users: {len(unique_users)}")
        for user in unique_users:
            if user != '-':
                user_events = len(self.df[self.df['TargetUserName'] == user])
                print(f"  {user}: {user_events} events")
        
        # Unique computers
        unique_computers = self.df['Computer'].dropna().unique()
        print(f"\nUnique Computers: {len(unique_computers)}")
        for computer in unique_computers:
            computer_events = len(self.df[self.df['Computer'] == computer])
            print(f"  {computer}: {computer_events} events")

def main():
    if len(sys.argv) < 2:
        print("Usage: python3 timeline_analyzer.py <csv_file> [username]")
        sys.exit(1)
    
    csv_file = sys.argv[1]
    username = sys.argv[2] if len(sys.argv) > 2 else None
    
    try:
        analyzer = InsiderActivityAnalyzer(csv_file)
        
        # Create timeline
        analyzer.create_user_timeline(username)
        
        # Detect suspicious patterns
        analyzer.detect_suspicious_patterns()
        
        # Generate summary report
        analyzer.generate_summary_report()
        
    except Exception as e:
        print(f"Error: {e}")

if __name__ == "__main__":
    main()
EOF

